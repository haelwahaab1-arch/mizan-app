    <script>
        // Tab Interaction Logic
        function activateTab(tabId) {
            // Hide all tab contents
            const contents = document.querySelectorAll('.tab-content');
            contents.forEach(content => {
                content.classList.remove('active');
            });
            
            // Reset all buttons styling
            const btns = document.querySelectorAll('.tab-btn');
            btns.forEach(btn => {
                btn.classList.remove('bg-primaryGreen', 'text-white', 'border-transparent');
                btn.classList.add('bg-white', 'text-gray-700', 'border-gray-300');
            });

            // Activate chosen tab and style button
            document.getElementById(tabId).classList.add('active');
            const activeBtn = document.getElementById('btn-' + tabId);
            activeBtn.classList.remove('bg-white', 'text-gray-700', 'border-gray-300');
            activeBtn.classList.add('bg-primaryGreen', 'text-white', 'border-transparent');
        }

        // Initialize Charts when DOM is fully loaded
        document.addEventListener('DOMContentLoaded', function() {
            
            // Chart 1: Foundations Doughnut Chart
            const fCtx = document.getElementById('foundationsChart').getContext('2d');
            new Chart(fCtx, {
                type: 'doughnut',
                data: {
                    labels: [
                        'المرجعيات الدينية (القرآنية)', 
                        'القانون المدني المصري', 
                        'قانون حماية البيانات الشخصية', 
                        'بروتوكول A.E.R التقني'
                    ],
                    datasets: [{
                        data: [25, 25, 25, 25],
                        backgroundColor: [
                            '#1B4332', // Primary Green
                            '#D4AF37', // Gold
                            '#2563EB', // Blue
                            '#4B5563'  // Gray
                        ],
                        borderWidth: 2,
                        borderColor: '#FDFBF7'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false, // Critical for CSS constraint
                    cutout: '65%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                font: { family: "'Cairo', sans-serif", size: 12 },
                                padding: 15,
                                color: '#1A1A1A'
                            }
                        },
                        tooltip: {
                            titleFont: { family: "'Cairo', sans-serif" },
                            bodyFont: { family: "'Cairo', sans-serif" }
                        }
                    }
                }
            });

            // Chart 2: Bottlenecks Radar Chart
            const rCtx = document.getElementById('bottleneckRadarChart').getContext('2d');
            new Chart(rCtx, {
                type: 'radar',
                data: {
                    labels: [
                        ['النطاق', 'الفرعي'], 
                        ['سياسات', 'الاستضافة'], 
